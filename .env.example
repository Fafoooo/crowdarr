# Runtime identity. Match the owner of files below MEDIA_ROOT.
PUID=1000
PGID=1000
UMASK=0022
TZ=Etc/UTC

# Single HTTP port and host-side persistent locations.
CROWDARRR_PORT=8000
CROWDARRR_CONFIG_ROOT=./config
MEDIA_ROOT=./media
CROWDARRR_IMAGE=crowdarrr:local
CROWDARRR_LOG_LEVEL=info

# Optional application protections. Leave blank for LAN/reverse-proxy-only use.
# Prefer leaving CROWDARRR_MASTER_KEY blank so Crowdarrr creates and persists one.
# When managed externally, it must be the exact output of Fernet.generate_key()
# (44 URL-safe base64 characters), never secrets.token_urlsafe(). Back it up with
# the database; a malformed or mismatched key makes startup fail safely.
CROWDARRR_API_TOKEN=
CROWDARRR_MASTER_KEY=

# Required only for the optional SABnzbd completion webhook. Use a distinct,
# randomly generated secret; requests larger than 64 KiB are rejected by default.
CROWDARRR_SAB_WEBHOOK_SECRET=
CROWDARRR_SAB_WEBHOOK_MAX_BYTES=65536

# Optional bounded-worker tuning. Values must be positive integers.
CROWDARRR_ACTION_MAX_CONCURRENCY=2
CROWDARRR_ACTION_MAX_PENDING=64
CROWDARRR_HASH_MAX_CONCURRENCY=2
CROWDARRR_QBIT_POLL_INTERVAL_SECONDS=30
CROWDARRR_HEALTHCHECK_TIMEOUT_SECONDS=5

# Used only by docker-compose.macvlan.example.yml; set an unused 10.10.3.x address.
CROWDARRR_MACVLAN_IP=

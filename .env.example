# Runtime identity. Match the owner of files below MEDIA_ROOT.
PUID=1000
PGID=1000
UMASK=0022
TZ=Etc/UTC

# Single HTTP port and persistent locations.
CROWDARRR_PORT=8000
CROWDARRR_DATA_DIR=/config
CROWDARRR_CONFIG_ROOT=./config
MEDIA_ROOT=./media
CROWDARRR_IMAGE=crowdarrr:local
CROWDARRR_LOG_LEVEL=info

# Optional application protections. Leave blank for LAN/reverse-proxy-only use.
# CROWDARRR_MASTER_KEY must be a Fernet key when set; back it up with the database.
CROWDARRR_API_TOKEN=
CROWDARRR_MASTER_KEY=

# Used only by docker-compose.macvlan.example.yml; set an unused 10.10.3.x address.
CROWDARRR_MACVLAN_IP=
